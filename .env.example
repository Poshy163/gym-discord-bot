# Bot token from the Discord developer portal (Bot -> Reset Token).
DISCORD_TOKEN=your-bot-token-here

# Optional: restrict auto-parsing to specific channels. Comma-separated IDs.
# Leave empty to scan every channel the bot can see.
GYM_CHANNEL_IDS=1494521271000764506

# Slash-command publishing scope:
#   global (default) — commands work in EVERY server the bot is in. First
#                      publish may take up to ~1h to propagate.
#   guild            — commands only registered to GUILD_ID for instant updates
#                      while developing (other servers get nothing).
COMMAND_SCOPE=global

# Optional: guild (server) ID used for instant slash-command sync when
# COMMAND_SCOPE=guild. Safe to leave set under COMMAND_SCOPE=global — the bot
# just clears that guild's old command copies so they don't duplicate the
# global ones.
GUILD_ID=974948447335620668

# Storage path inside the container (mapped to the gym-data volume).
DB_PATH=/data/gym.sqlite3

# Minimum number of detected lifts in one message before it is auto-stored.
MIN_LIFTS_FOR_AUTO=2
# Max lift rows shown in parser confirmation replies. 0 = show every lift.
PARSE_REPLY_MAX_ITEMS=15

# On startup, scan the recent history of each GYM_CHANNEL_IDS channel and
# import any posts the bot missed while offline. Safe to leave on — duplicates
# are ignored via (message_id, equipment).
BACKFILL_ON_START=true
# How many recent messages per channel to scan on startup. 0 = no limit.
BACKFILL_LIMIT=1000

# When true, weights are shown with an approximate lb conversion alongside kg
# (e.g. "80kg (≈176.4 lb)"). Set to true if anyone in your server prefers lb.
SHOW_LB=false

# Safety cap for logged weights. Anything above this is skipped as likely fake
# or a typo (e.g. 2200kg). Set 0 to disable.
MAX_WEIGHT_KG=500

# Timezone used when displaying dates in user-facing messages and scheduling
# the weekly reminder. Any zoneinfo name (e.g. Australia/Adelaide, UTC,
# Europe/London). Defaults to Australia/Adelaide.
DISPLAY_TIMEZONE=Australia/Adelaide

# --- Weekly check-in reminder ---------------------------------------------
# Channel the bot should post the weekly "drop your current bests" reminder
# in. Leave blank to disable. When set, the bot posts on REMINDER_WEEKDAY at
# REMINDER_HOUR:REMINDER_MINUTE in DISPLAY_TIMEZONE.
REMINDER_CHANNEL_ID=
# 0=Monday … 2=Wednesday … 6=Sunday
REMINDER_WEEKDAY=2
REMINDER_HOUR=12
REMINDER_MINUTE=0
# Optional role ID to @mention in the reminder (leave blank for no ping).
REMINDER_ROLE_ID=

# --- Weekly bodyweight reminder -------------------------------------------
# Channel the bot posts the weekly bodyweight check-in in. Leave blank to
# inherit REMINDER_CHANNEL_ID; set explicitly to override or to disable
# (set to a channel different from REMINDER_CHANNEL_ID, or leave both blank
# to disable both reminders). Default is Monday 07:30 in DISPLAY_TIMEZONE.
BODYWEIGHT_REMINDER_CHANNEL_ID=
BODYWEIGHT_REMINDER_WEEKDAY=0
BODYWEIGHT_REMINDER_HOUR=7
BODYWEIGHT_REMINDER_MINUTE=30
BODYWEIGHT_REMINDER_ROLE_ID=

# --- Daily gym update ------------------------------------------------------
# Channel the bot should post yesterday's activity recap in. Leave blank to
# disable. Empty days are skipped unless DAILY_UPDATE_POST_EMPTY=true.
DAILY_UPDATE_CHANNEL_ID=
DAILY_UPDATE_HOUR=8
DAILY_UPDATE_MINUTE=0
DAILY_UPDATE_POST_EMPTY=false

# --- Weekly report (gym recap + AI calorie summaries) -----------------------
# Channel for the Sunday-evening weekly report: a 7-day gym recap plus an AI
# calorie summary for everyone tracking via /calories. Leave blank to inherit
# DAILY_UPDATE_CHANNEL_ID (then REMINDER_CHANNEL_ID); leave all blank to
# disable. AI summaries need GEMINI_API_KEY (below) — without it the report
# falls back to plain stats lines.
WEEKLY_REPORT_CHANNEL_ID=
# 0=Monday … 6=Sunday
WEEKLY_REPORT_WEEKDAY=6
WEEKLY_REPORT_HOUR=18
WEEKLY_REPORT_MINUTE=0

# --- Sleep analysis (Gemini) ----------------------------------------------
# Optional: enables `/track analyze`, which sends a tracked user's derived
# sleep sessions to Google's Gemini API and returns plain-language trends.
# Leave GEMINI_API_KEY blank to disable. Get a key at
# https://aistudio.google.com/apikey. GEMINI_MODEL is optional and defaults
# to gemini-2.5-flash. Requires the `requests` package (already a dependency).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Transient failures (HTTP 429/500/503/504 — e.g. "model is busy, high demand")
# are retried automatically. Number of retries after the first attempt; 0
# disables. Optional.
GEMINI_MAX_RETRIES=2
# Seconds to wait between retries. Leave at 0 to use an escalating backoff
# (1.5s, 3s, 4.5s…); set a number for a fixed delay instead. Optional.
GEMINI_RETRY_DELAY=0
# Fallback model tried if the primary is still overloaded/unreachable after its
# retries (e.g. flash is swamped → fall back to flash-lite). Leave blank to
# disable. Must be a different model id from GEMINI_MODEL. Optional.
BACKUP_GEMINI_MODEL=

# --- Strava integration (real-time workout posts) --------------------------
# Posts an embed to STRAVA_FEED_CHANNEL_ID whenever a linked member finishes a
# Strava activity. Uses OAuth2 + Strava's webhook push, so the bot runs a tiny
# web server that MUST be reachable from the public internet over HTTPS. See
# docs/STRAVA.md for the full walkthrough (registering the API app, etc.).
#
# Set STRAVA_DISABLED=1 to switch the whole feature off.
STRAVA_DISABLED=0
# From your Strava API application (https://www.strava.com/settings/api).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Public HTTPS base URL that reaches this bot's web server. The OAuth callback
# and webhook are derived as <base>/strava/callback and <base>/strava/webhook.
# This same domain must be set as the "Authorization Callback Domain" in the
# Strava API app settings.
STRAVA_PUBLIC_URL=
# Channel every linked athlete's workouts post into.
STRAVA_FEED_CHANNEL_ID=
# Shared secret echoed during the webhook subscription handshake (any string).
STRAVA_WEBHOOK_VERIFY_TOKEN=gymbot
# Auto-create the webhook subscription on startup and on link, so you never run
# /strava_subscribe by hand. Needs the public callback reachable when it runs.
# Set to 0 to manage the subscription manually.
STRAVA_AUTO_SUBSCRIBE=1
# Host/port the web server binds to inside the container (map/proxy as needed).
STRAVA_BIND_HOST=0.0.0.0
STRAVA_PORT=8080
# Fernet key used to encrypt stored Strava tokens. Falls back to REVO_FERNET_KEY
# if unset, so one key can serve both. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STRAVA_FERNET_KEY=
# Optional: a Mapbox access token renders route maps over a real basemap
# (streets/terrain), like the Strava website, instead of a plain line drawing.
# Free tier at https://account.mapbox.com/access-tokens/. Leave blank to use the
# built-in local silhouette renderer. Note: privacy-zoned ("hidden") portions of
# a route are stripped by Strava before the API ever sends them — no token can
# recover those; adjust your Strava privacy zones if you want the full track.
STRAVA_MAPBOX_TOKEN=
# Mapbox style for the route map (only used when a token is set). Options:
# outdoors-v12 (default, trails/terrain), streets-v12 (road map),
# satellite-streets-v12 (aerial imagery + labels).
STRAVA_MAP_STYLE=outdoors-v12
# Optional posting filters (all default off):
#  - STRAVA_SPORT_TYPES: comma-separated allow-list of Strava sport_type values
#    (e.g. "Run,Ride,WeightTraining"). Empty = post every type.
#  - STRAVA_MIN_DISTANCE_M: skip distance-sport activities shorter than this
#    many metres (e.g. 1000 to ignore <1km walks). 0 = no minimum.
#  - STRAVA_MIN_DURATION_S: skip activities shorter than this many seconds.
STRAVA_SPORT_TYPES=
STRAVA_MIN_DISTANCE_M=0
STRAVA_MIN_DURATION_S=0
# Show distances/pace/elevation/temperature in imperial units (mi/ft/°F).
# Default is metric (km/m/°C).
STRAVA_IMPERIAL=0

# ---------------------------------------------------------------------------
# Web dashboard (app/webui.py)
# ---------------------------------------------------------------------------
# An authenticated operator dashboard on its own port for browsing and editing
# everything the bot tracks (lifts / calories / protein / bodyweight), viewing
# each member's roles, and reading a unified audit log of role changes, member
# join/leave/rename, and data edits.
#
# It is DISABLED until you set WEBUI_PASSWORD — the dashboard exposes member
# data, so it must never run without a login secret. Enabling it also turns on
# the privileged Server Members intent, which you must additionally toggle ON
# for the bot in the Discord Developer Portal (Bot → Privileged Gateway
# Intents → Server Members Intent), otherwise the gateway connection is refused.
#
# Single shared login password. Leave blank to keep the dashboard off.
WEBUI_PASSWORD=
# Hard kill-switch: set to 1 to force the dashboard off even if a password is set.
WEBUI_DISABLED=0
# Host/port the dashboard binds to inside the container (map/proxy as needed).
# Use a different host port from STRAVA_PORT. Front it with HTTPS in production.
WEBUI_BIND_HOST=0.0.0.0
WEBUI_PORT=8081

# ---------------------------------------------------------------------------
# Message logging & media archive (dashboard "Messages" tab)
# ---------------------------------------------------------------------------
# Captures every member's messages (full content) across all channels, plus a
# permanent local copy of every uploaded attachment (images, videos, any file)
# so they survive Discord's expiring CDN links and message deletion. Edited
# messages are kept faithful to their latest text/media, and deleted messages
# are flagged (not dropped). Needs the Message Content intent (already enabled).
#
# Master switch for logging. Default true; set false to disable entirely.
ENABLE_MESSAGE_LOGGING=true
# Days of channel history to scan on startup so the feed isn't empty. 0 disables.
MESSAGE_LOG_BACKFILL_DAYS=30
# Download uploaded attachments to disk (vs. keeping only the expiring URL).
ENABLE_MEDIA_DOWNLOAD=true
# Where downloaded media is stored. Defaults to a "media" folder next to DB_PATH
# (e.g. /data/media); put it on a persistent volume so it isn't lost on restart.
# MEDIA_DIR=/data/media
# Skip downloading attachments larger than this (MB); they keep the remote URL.
# 0 means no cap.
MEDIA_MAX_MB=50

# ---------------------------------------------------------------------------
# Auto un-timeout
# ---------------------------------------------------------------------------
# When ON, the bot immediately clears any timeout placed on a member (the moment
# their "communication disabled until" is set to a future time). Needs the bot's
# Moderate Members permission and a role above the target — Discord enforces both,
# and the bot can never act on members it doesn't outrank or on the guild owner.
# Every removal is recorded in the dashboard audit log. Enabling this also turns
# on the Server Members intent (toggle it ON in the Developer Portal too).
# Default true; set false to disable.
AUTO_UNTIMEOUT=true

LOG_LEVEL=INFO